{
    "appId": "com.seluna.app",
    "appName": "Seluna",
    "webDir": "Seluna_frontend",
    "bundledWebRuntime": false,
        "plugins": {
            "StatusBar": {
            "style": "LIGHT",
            "backgroundColor": "#ffffff",
            "overlaysWebView": false
            },
        "SplashScreen": {
            "launchShowDuration": 2000,
            "backgroundColor": "#000000",
            "androidScaleType": "CENTER_CROP"
        },
        "Keyboard": {
            "resize": "native"
        }
    }
}